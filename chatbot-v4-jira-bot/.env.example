# ── Databricks ──────────────────────────────────────────────────────────────
# Direct Bearer token auth — no Databricks CLI setup required for local dev.
# The DATABRICKS_TOKEN + JIRA_EMAIL combo bypasses the Databricks SCIM lookup
# and uses JIRA_EMAIL as the user identity automatically.
DATABRICKS_HOST=https://innocean-usa-ds-hma-prod.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_pat_token_here
DATABRICKS_SERVING_ENDPOINT=databricks-gpt-5-2

# Leave blank — DATABRICKS_TOKEN above takes precedence over CLI profile.
# Set this only if you are using Databricks CLI (databricks auth login).
DATABRICKS_CONFIG_PROFILE=

# ── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://innoceanusa.atlassian.net
JIRA_EMAIL=your_jira_email@innoceanusa.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Database (Lakebase PostgreSQL for persistent chat history) ────────────
# Option A: Full connection string (recommended)
POSTGRES_URL=postgresql://user:password@host:5432/jira-bot-chat

# Option B: Individual variables (alternative to POSTGRES_URL)
# PGUSER=
# PGHOST=
# PGPORT=5432
# PGDATABASE=jira-bot-chat
# PGPASSWORD=

# Leave database vars empty to run in ephemeral mode (no chat history saved).

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
